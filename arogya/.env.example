# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:5000

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_hex
JWT_EXPIRES_IN=7d

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_SECRET=replace_with_another_random_string

# ── Google OAuth ──────────────────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com
# 2. APIs & Services → Credentials → Create OAuth 2.0 Client ID (Web application)
# 3. Authorized redirect URI: https://your-railway-domain/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ── Anthropic (online AI) ─────────────────────────────────────────────────────
# Get from: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ── Ollama (offline AI) ───────────────────────────────────────────────────────
# Local dev: run `ollama serve` and `ollama pull llama3`
# Railway:   deploy Ollama as a separate service, paste its internal URL here
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Railway MongoDB plugin: copy the connection string from the plugin dashboard
# Atlas: mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
# MONGODB_URI=mongodb://localhost:27017
MONGODB_URI=mongodb+srv://mayurterekar712_db_user:mayur123@cluster0.9mjdewr.mongodb.net/?appName=Cluster0
MONGODB_DB_NAME=arogya
